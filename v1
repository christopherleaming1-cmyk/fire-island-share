  import { GUEST_COLORS, COST_PER_PERSON_WEEK } from '../data';

  const fmt = (n) => n.toLocaleString('en-US', { minimumFractionDigits: 2,
  maximumFractionDigits: 2 });

  export default function GuestRoster({ guestRoster }) {
    if (!guestRoster || guestRoster.length === 0) {
      return (
        <div className="bg-white border border-zinc-200 rounded-xl py-16
  text-center">
          <p className="text-sm font-medium text-zinc-400">No guests yet — add
  them in the Grid.</p>
        </div>
      );
    }

    const totalOutstanding = guestRoster.reduce((sum, entry) => sum +
  (entry.totalOwed - entry.totalPaid), 0);

    return (
      <div className="space-y-4">
        <div className="bg-white border border-zinc-200 rounded-xl
  overflow-hidden divide-y divide-zinc-100">
          {guestRoster.map(entry => {
            const color = GUEST_COLORS[entry.colorIdx % GUEST_COLORS.length];
            const pending = entry.totalOwed - entry.totalPaid;
            const paidCount = entry.slots.filter(s => s.paid).length;
            const pendingCount = entry.slots.length - paidCount;

            return (
              <div key={entry.name} className="px-5 py-4 flex items-start
  gap-4">
                <div className="flex-1 min-w-0">
                  <div className="flex items-center gap-2 mb-2">
                    <span className={`w-2.5 h-2.5 rounded-full flex-shrink-0 
  ${color.dot}`} />
                    <span className="font-semibold
  text-slate-900">{entry.name}</span>
                  </div>
                  <div className="flex flex-wrap gap-1.5 mb-2">
                    {entry.slots.map((slot, i) => (
                      <span key={i} className="inline-flex items-center gap-1
  px-2 py-0.5 rounded-full text-[10px] font-medium bg-zinc-100 text-zinc-600">
                        {slot.week}
                      </span>
                    ))}
                  </div>
                  <div className="space-y-0.5">
                    {entry.slots.map((slot, i) => (
                      <p key={i} className="text-xs text-zinc-400">
                        {slot.room} · {slot.owner}
                        {slot.paid
                          ? <span className="text-emerald-500 ml-1">·
  paid</span>
                          : <span className="text-amber-500 ml-1">·
  pending</span>
                        }
                      </p>
                    ))}
                  </div>
                </div>
                <div className="text-right flex-shrink-0">
                  <p className="font-bold text-slate-900
  tabular-nums">${fmt(entry.totalOwed)}</p>
                  <p className="text-xs text-zinc-400 mt-0.5">
                    {paidCount > 0 && <span 
  className="text-emerald-500">{paidCount} paid</span>}
                    {paidCount > 0 && pendingCount > 0 && <span 
  className="text-zinc-300"> · </span>}
                    {pendingCount > 0 && <span 
  className="text-amber-500">{pendingCount} pending</span>}
                  </p>
                </div>
              </div>
            );
          })}
        </div>

        <div className="bg-white border border-zinc-200 rounded-xl px-5 py-4
  flex items-center justify-between text-sm">
          <span className="text-zinc-500">Total outstanding across all
  guests</span>
          <span className="font-bold text-lg text-amber-500
  tabular-nums">${fmt(totalOutstanding)}</span>
        </div>
      </div>
    );
  }

