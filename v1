  ---
  src/App.jsx
  import { useState, useMemo } from 'react';
  import { Waves } from 'lucide-react';
  import Dashboard from './components/Dashboard';
  import WeekGrid from './components/WeekGrid';
  import GuestModal from './components/GuestModal';
  import GuestRoster from './components/GuestRoster';
  import InterestQueue from './components/InterestQueue';
  import ReimbursementTable from './components/ReimbursementTable';
  import { WEEKS, ROOMS, OWNERS, COST_PER_PERSON_WEEK, TOTAL_SEASON_COST,
  buildInitialGrid } from './data';

  const TABS = [
    { id: 'grid',          label: 'Grid'           },
    { id: 'guests',        label: 'Guests'         },
    { id: 'queue',         label: 'Interest Queue' },
    { id: 'reimbursement', label: 'Reimbursements' },
  ];

  export default function App() {
    const [grid, setGrid]                   = useState(buildInitialGrid);
    const [modal, setModal]                 = useState(null);
    const [activeTab, setActiveTab]         = useState('grid');
    const [guestRegistry, setGuestRegistry] = useState({});

    const openModal = (weekId, roomId, slotIdx) =>
      setModal({ weekId, roomId, slotIdx, slot: grid[weekId][roomId][slotIdx]
  });

    const closeModal = () => setModal(null);

    const saveSlot = ({ name, paid }) => {
      const { weekId, roomId, slotIdx } = modal;
      const ownerName = ROOMS.find(r => r.id === roomId).owner;
      const trimmed   = name.trim();
      const isOwner   = !trimmed;

      if (!isOwner) {
        setGuestRegistry(prev => {
          if (prev[trimmed]) return prev;
          const usedIndices = Object.values(prev).map(v => v.colorIdx);
          let nextIdx = 0;
          while (usedIndices.includes(nextIdx)) nextIdx++;
          return { ...prev, [trimmed]: { colorIdx: nextIdx } };
        });
      }

      setGrid(prev => {
        const slots = [...prev[weekId][roomId]];
        slots[slotIdx] = { name: isOwner ? ownerName : trimmed, paid: isOwner ?
  false : paid, isOwner };
        return { ...prev, [weekId]: { ...prev[weekId], [roomId]: slots } };
      });
      closeModal();
    };

    const moveGuest = (src, dst) => {
      if (src.weekId === dst.weekId && src.roomId === dst.roomId && src.slotIdx
  === dst.slotIdx) return;
      setGrid(prev => {
        const newGrid = JSON.parse(JSON.stringify(prev));
        const srcSlot = newGrid[src.weekId][src.roomId][src.slotIdx];
        const dstSlot = newGrid[dst.weekId][dst.roomId][dst.slotIdx];
        if (dstSlot.isOwner) {
          const srcOwnerName = ROOMS.find(r => r.id === src.roomId).owner;
          newGrid[dst.weekId][dst.roomId][dst.slotIdx] = { ...srcSlot };
          newGrid[src.weekId][src.roomId][src.slotIdx] = { name: srcOwnerName,
  paid: false, isOwner: true };
        } else {
          newGrid[dst.weekId][dst.roomId][dst.slotIdx] = { ...srcSlot };
          newGrid[src.weekId][src.roomId][src.slotIdx] = { ...dstSlot };
        }
        return newGrid;
      });
    };

    const togglePaid = (weekId, roomId, slotIdx) => {
      setGrid(prev => {
        const slots = [...prev[weekId][roomId]];
        if (slots[slotIdx].isOwner) return prev;
        slots[slotIdx] = { ...slots[slotIdx], paid: !slots[slotIdx].paid };
        return { ...prev, [weekId]: { ...prev[weekId], [roomId]: slots } };
      });
    };

    const ownerStats = OWNERS.map(owner => {
      const ownerRooms = ROOMS.filter(r => owner.rooms.includes(r.id));
      let recovered = 0, totalGuests = 0, paidGuests = 0;
      ownerRooms.forEach(room => {
        WEEKS.forEach(week => {
          grid[week.id][room.id].forEach(slot => {
            if (!slot.isOwner) {
              totalGuests++;
              if (slot.paid) { recovered += COST_PER_PERSON_WEEK; paidGuests++;
  }
            }
          });
        });
      });
      return { ...owner, recovered, remaining: owner.fronted - recovered,
  totalGuests, paidGuests };
    });

    const totalRecovered = ownerStats.reduce((s, o) => s + o.recovered, 0);

    const reimbursements = [];
    WEEKS.forEach(week => {
      ROOMS.forEach(room => {
        const owner = OWNERS.find(o => o.name === room.owner);
        grid[week.id][room.id].forEach((slot, slotIdx) => {
          if (!slot.isOwner) {
            reimbursements.push({
              guest: slot.name, week: week.label, dates: week.dates,
              room: room.label, owner: room.owner, ownerData: owner,
              amount: COST_PER_PERSON_WEEK, paid: slot.paid,
              weekId: week.id, roomId: room.id, slotIdx,
            });
          }
        });
      });
    });

    const guestRoster = useMemo(() => {
      const map = {};
      WEEKS.forEach(week => {
        ROOMS.forEach(room => {
          const owner = OWNERS.find(o => o.name === room.owner);
          grid[week.id][room.id].forEach(slot => {
            if (!slot.isOwner) {
              if (!map[slot.name]) {
                map[slot.name] = { name: slot.name, colorIdx:
  guestRegistry[slot.name]?.colorIdx ?? 0, slots: [] };
              }
              map[slot.name].slots.push({ week: week.label, dates: week.dates,
  room: room.label, owner: room.owner, ownerData: owner, paid: slot.paid });
            }
          });
        });
      });
      return Object.values(map).map(entry => {
        const totalOwed = entry.slots.length * COST_PER_PERSON_WEEK;
        const totalPaid = entry.slots.filter(s => s.paid).length *
  COST_PER_PERSON_WEEK;
        return { ...entry, totalOwed, totalPaid };
      });
    }, [grid, guestRegistry]);

    const knownGuests = Object.keys(guestRegistry);

    return (
      <div className="min-h-screen bg-zinc-50 font-sans">
        <header className="bg-slate-900 text-white">
          <div className="max-w-6xl mx-auto px-5 py-4 flex items-center
  justify-between">
            <div className="flex items-center gap-3">
              <Waves className="w-5 h-5 text-sky-400" strokeWidth={2} />
              <div>
                <h1 className="text-base font-semibold tracking-tight">Fire
  Island Share Manager</h1>
                <p className="text-zinc-500 text-xs mt-0.5">Summer 2025 · 5
  weeks · 4 rooms · $828 / person / week</p>
              </div>
            </div>
            <div className="hidden sm:flex items-center gap-2">
              {OWNERS.map(o => (
                <span key={o.name} className="flex items-center gap-1.5 text-xs
  text-zinc-400">
                  <span className={`w-2 h-2 rounded-full ${o.dot}`} />
                  {o.name}
                </span>
              ))}
            </div>
          </div>
        </header>

        <main className="max-w-6xl mx-auto px-4 sm:px-5 py-6 space-y-6">
          <Dashboard ownerStats={ownerStats} totalRecovered={totalRecovered} 
  totalCost={TOTAL_SEASON_COST} />

          <div className="border-b border-zinc-200">
            <nav className="flex gap-0">
              {TABS.map(tab => (
                <button
                  key={tab.id}
                  onClick={() => setActiveTab(tab.id)}
                  className={`px-4 py-2.5 text-sm font-medium border-b-2
  transition-colors -mb-px ${
                    activeTab === tab.id
                      ? 'border-slate-900 text-slate-900'
                      : 'border-transparent text-zinc-500 hover:text-zinc-700
  hover:border-zinc-300'
                  }`}
                >
                  {tab.label}
                </button>
              ))}
            </nav>
          </div>

          {activeTab === 'grid'          && <WeekGrid grid={grid} 
  onSlotClick={openModal} onTogglePaid={togglePaid} 
  guestRegistry={guestRegistry} onMove={moveGuest} />}
          {activeTab === 'guests'        && <GuestRoster 
  guestRoster={guestRoster} />}
          {activeTab === 'queue'         && <InterestQueue />}
          {activeTab === 'reimbursement' && <ReimbursementTable 
  reimbursements={reimbursements} ownerStats={ownerStats} />}
        </main>

        <footer className="text-center py-8 text-xs text-zinc-400">
          Rhys · Chris · Michael · Fire Island 2025
        </footer>

        {modal && (
          <GuestModal
            slot={modal.slot}
            room={ROOMS.find(r => r.id === modal.roomId)}
            week={WEEKS.find(w => w.id === modal.weekId)}
            onSave={saveSlot}
            onClose={closeModal}
            knownGuests={knownGuests}
            guestRegistry={guestRegistry}
          />
        )}
      </div>
    );
  }

  ---
  src/components/Dashboard.jsx
  const fmt = (n) => n.toLocaleString('en-US', { minimumFractionDigits: 2,
  maximumFractionDigits: 2 });
  const pct  = (a, b) => b > 0 ? Math.min(100, Math.round((a / b) * 100)) : 0;

  function MetricCard({ label, value, sub, valueClass = 'text-slate-900' }) {
    return (
      <div className="bg-white border border-zinc-200 rounded-xl p-5">
        <p className="text-xs font-medium text-zinc-400 uppercase tracking-wider
   mb-2">{label}</p>
        <p className={`text-2xl font-bold tabular-nums 
  ${valueClass}`}>{value}</p>
        {sub && <p className="text-xs text-zinc-400 mt-1">{sub}</p>}
      </div>
    );
  }

  export default function Dashboard({ ownerStats, totalRecovered, totalCost }) {
    const totalRemaining = totalCost - totalRecovered;

    return (
      <div className="space-y-4">
        <div className="grid grid-cols-3 gap-3">
          <MetricCard label="Season Cost" 
  value={`$${totalCost.toLocaleString()}`} sub="Rent + utils + fees" />
          <MetricCard label="Recovered" value={`$${fmt(totalRecovered)}`}
  valueClass="text-emerald-600" sub={`${pct(totalRecovered, totalCost)}% of 
  season`} />
          <MetricCard label="Still Owed" value={`$${fmt(totalRemaining)}`}
  valueClass={totalRemaining > 0 ? 'text-red-500' : 'text-emerald-600'}
  sub="Across all owners" />
        </div>

        <div className="grid grid-cols-1 sm:grid-cols-3 gap-3">
          {ownerStats.map(owner => {
            const progress = pct(owner.recovered, owner.fronted);
            return (
              <div key={owner.name} className="bg-white border border-zinc-200
  rounded-xl overflow-hidden">
                <div className={`h-1 ${owner.bar}`} style={{ width: 
  `${progress}%`, transition: 'width 0.5s ease' }} />
                <div className="h-1 bg-zinc-100 -mt-1" />
                <div className="p-5">
                  <div className="flex items-center justify-between mb-4">
                    <div className="flex items-center gap-2">
                      <span className={`w-2.5 h-2.5 rounded-full ${owner.dot}
  flex-shrink-0`} />
                      <span className="font-semibold
  text-slate-900">{owner.name}</span>
                    </div>
                    <span className="text-xs font-medium
  text-zinc-400">{progress}% back</span>
                  </div>
                  <dl className="space-y-2 text-sm">
                    <div className="flex justify-between">
                      <dt className="text-zinc-500">Fronted</dt>
                      <dd className="font-medium text-slate-900
  tabular-nums">${fmt(owner.fronted)}</dd>
                    </div>
                    <div className="flex justify-between">
                      <dt className="text-zinc-500">Recovered</dt>
                      <dd className="font-medium text-emerald-600
  tabular-nums">+${fmt(owner.recovered)}</dd>
                    </div>
                    <div className="flex justify-between pt-2 border-t
  border-zinc-100">
                      <dt className="font-medium text-zinc-700">Owed back</dt>
                      <dd className={`font-bold tabular-nums ${owner.remaining >
   0 ? 'text-red-500' : 'text-emerald-600'}`}>
                        ${fmt(owner.remaining)}
                      </dd>
                    </div>
                  </dl>
                  <div className="mt-4 h-1.5 bg-zinc-100 rounded-full
  overflow-hidden">
                    <div className={`h-full ${owner.bar} rounded-full 
  transition-all duration-500`} style={{ width: `${progress}%` }} />
                  </div>
                  <p className="text-xs text-zinc-400 mt-1.5">{owner.paidGuests}
   / {owner.totalGuests} guest slots paid</p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    );
  }

  ---
  src/components/WeekGrid.jsx
  import { useRef, useState } from 'react';
  import { Plus, Check, Minus } from 'lucide-react';
  import { WEEKS, ROOMS, OWNERS, GUEST_COLORS } from '../data';

  const OWNER_MAP = Object.fromEntries(OWNERS.map(o => [o.name, o]));

  function Slot({ slot, weekId, roomId, slotIdx, ownerName, onEdit,
  onTogglePaid, guestRegistry, isDragOver, isDragging, onDragStart, onDragOver,
  onDragEnd, onDrop }) {
    const slotKey = `${weekId}-${roomId}-${slotIdx}`;
    const dropRing = isDragOver ? 'ring-2 ring-slate-400 ring-offset-1' : '';

    if (slot.isOwner) {
      return (
        <button
          onClick={() => onEdit(weekId, roomId, slotIdx)}
          onDragOver={(e) => onDragOver(e, slotKey)}
          onDrop={(e) => onDrop(e, weekId, roomId, slotIdx)}
          className={`w-full flex items-center gap-2 px-2.5 py-2 rounded-lg
  bg-zinc-50 border border-dashed border-zinc-300 text-zinc-400
  hover:border-zinc-400 hover:text-zinc-600 hover:bg-zinc-100 transition-all
  group text-left ${dropRing}`}
        >
          <Plus className="w-3 h-3 flex-shrink-0 group-hover:text-zinc-600" />
          <span className="text-xs font-medium truncate">Add guest</span>
        </button>
      );
    }

    const colorIdx = guestRegistry[slot.name]?.colorIdx ?? 0;
    const dotClass = GUEST_COLORS[colorIdx % GUEST_COLORS.length].dot;

    return (
      <div
        draggable
        onDragStart={(e) => onDragStart(e, weekId, roomId, slotIdx)}
        onDragOver={(e) => onDragOver(e, slotKey)}
        onDrop={(e) => onDrop(e, weekId, roomId, slotIdx)}
        onDragEnd={onDragEnd}
        className={`w-full flex items-center gap-2 px-2.5 py-2 rounded-lg border
   text-left transition-all cursor-grab
          ${slot.paid ? 'bg-white border-emerald-200 border-l-2
  border-l-emerald-400' : 'bg-white border-zinc-200 border-l-2
  border-l-amber-400'}
          ${isDragging ? 'opacity-40 cursor-grabbing' : ''}
          ${dropRing}`}
      >
        <span className={`w-2 h-2 rounded-full flex-shrink-0 ${dotClass}`} />
        <div className="flex-1 min-w-0">
          <p className="text-xs font-semibold text-slate-800 truncate
  leading-tight">{slot.name}</p>
          <p className={`text-[10px] font-medium mt-0.5 ${slot.paid ?
  'text-emerald-500' : 'text-amber-500'}`}>
            {slot.paid ? 'Paid' : 'Unpaid'} · $828
          </p>
        </div>
        <div className="flex gap-1 flex-shrink-0">
          <button
            onClick={() => onTogglePaid(weekId, roomId, slotIdx)}
            title={slot.paid ? 'Mark unpaid' : 'Mark paid'}
            className={`w-5 h-5 rounded flex items-center justify-center
  transition-all ${slot.paid ? 'bg-emerald-100 text-emerald-600
  hover:bg-emerald-200' : 'bg-zinc-100 text-zinc-400 hover:bg-emerald-100
  hover:text-emerald-600'}`}
          >
            {slot.paid ? <Check className="w-3 h-3" /> : <Minus className="w-3
  h-3" />}
          </button>
          <button
            onClick={() => onEdit(weekId, roomId, slotIdx)}
            className="w-5 h-5 rounded bg-zinc-100 text-zinc-400
  hover:bg-zinc-200 flex items-center justify-center transition-all"
          >
            <svg className="w-2.5 h-2.5" fill="none" stroke="currentColor" 
  viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" 
  strokeWidth={2.5} d="M15.232 5.232l3.536 3.536M9 11l6.536-6.536a2 2 0 012.828
  2.828L11.828 13.828a4 4 0 01-1.414.94l-3.414.854.854-3.414a4 4 0 01.94-1.414z"
   />
            </svg>
          </button>
        </div>
      </div>
    );
  }

  export default function WeekGrid({ grid, onSlotClick, onTogglePaid,
  guestRegistry, onMove }) {
    const dragSrc = useRef(null);
    const [dragOverKey, setDragOverKey] = useState(null);
    const [draggingKey, setDraggingKey] = useState(null);

    const handleDragStart = (e, weekId, roomId, slotIdx) => {
      dragSrc.current = { weekId, roomId, slotIdx };
      setDraggingKey(`${weekId}-${roomId}-${slotIdx}`);
      e.dataTransfer.effectAllowed = 'move';
    };

    const handleDragOver = (e, key) => {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      setDragOverKey(key);
    };

    const handleDrop = (e, weekId, roomId, slotIdx) => {
      e.preventDefault();
      setDragOverKey(null);
      if (dragSrc.current) {
        onMove(dragSrc.current, { weekId, roomId, slotIdx });
        dragSrc.current = null;
      }
      setDraggingKey(null);
    };

    const handleDragEnd = () => {
      setDragOverKey(null);
      setDraggingKey(null);
      dragSrc.current = null;
    };

    return (
