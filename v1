  src/components/GuestModal.jsx
  import { useState, useEffect, useRef } from 'react';
  import { X, Trash2 } from 'lucide-react';
  import { COST_PER_PERSON_WEEK, GUEST_COLORS } from '../data';

  export default function GuestModal({ slot, room, week, onSave, onClose,
  knownGuests = [], guestRegistry = {} }) {
    const [guestName, setGuestName]       = useState(slot.isOwner ? '' :
  slot.name);
    const [paid, setPaid]                 = useState(slot.paid);
    const [showDropdown, setShowDropdown] = useState(false);
    const inputRef                        = useRef(null);

    useEffect(() => {
      const onKey = (e) => { if (e.key === 'Escape') onClose(); };
      document.addEventListener('keydown', onKey);
      inputRef.current?.focus();
      return () => document.removeEventListener('keydown', onKey);
    }, [onClose]);

    const isGuest = !!guestName.trim();
    const handleSave  = () => onSave({ name: guestName, paid: isGuest ? paid :
  false });
    const handleClear = () => onSave({ name: '', paid: false });

    const suggestions = knownGuests
      .filter(name => name.toLowerCase().includes(guestName.toLowerCase()) &&
  name.toLowerCase() !== guestName.toLowerCase())
      .slice(0, 6);

    const selectSuggestion = (name) => {
      setGuestName(name);
      setShowDropdown(false);
    };

    return (
      <div
        className="fixed inset-0 bg-black/60 flex items-end sm:items-center
  justify-center z-50 p-0 sm:p-4"
        onClick={(e) => { if (e.target === e.currentTarget) onClose(); }}
      >
        <div className="bg-white w-full sm:max-w-sm rounded-t-2xl sm:rounded-2xl
   overflow-hidden shadow-2xl">
          <div className="flex items-center justify-between px-5 pt-5 pb-4
  border-b border-zinc-100">
            <div>
              <h2 className="font-semibold text-slate-900">Assign Guest</h2>
              <p className="text-xs text-zinc-400 mt-0.5">
                {week.label} · {week.dates} · {room.label}
              </p>
            </div>
            <button onClick={onClose} className="w-8 h-8 flex items-center
  justify-center rounded-lg hover:bg-zinc-100 text-zinc-400 transition-colors">
              <X className="w-4 h-4" />
            </button>
          </div>

          <div className="px-5 py-4 space-y-4">
            <div className="flex items-center justify-between text-sm">
              <span className="text-zinc-500">Room owner</span>
              <span className="font-medium text-slate-900">{room.owner}</span>
            </div>

            <div>
              <label className="block text-xs font-semibold text-zinc-600
  uppercase tracking-wider mb-1.5">
                Guest Name
              </label>
              <div className="relative">
                <input
                  ref={inputRef}
                  type="text"
                  value={guestName}
                  onChange={e => { setGuestName(e.target.value);
  setShowDropdown(true); }}
                  onFocus={() => setShowDropdown(true)}
                  onBlur={() => setShowDropdown(false)}
                  onKeyDown={e => { if (e.key === 'Enter') handleSave(); }}
                  placeholder={`Leave blank to keep as ${room.owner}`}
                  className="w-full px-3 py-2.5 border border-zinc-200
  rounded-lg text-sm text-slate-900 placeholder:text-zinc-300 focus:outline-none
   focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all"
                />
                {showDropdown && suggestions.length > 0 && (
                  <ul className="absolute left-0 right-0 top-full mt-1 bg-white
  border border-zinc-200 rounded-lg shadow-md z-50 overflow-hidden">
                    {suggestions.map(name => {
                      const colorIdx = guestRegistry[name]?.colorIdx ?? 0;
                      const dotClass = GUEST_COLORS[colorIdx %
  GUEST_COLORS.length].dot;
                      return (
                        <li key={name}>
                          <button
                            type="button"
                            onMouseDown={(e) => { e.preventDefault();
  selectSuggestion(name); }}
                            className="w-full flex items-center gap-2.5 px-3
  py-2.5 text-sm text-slate-800 hover:bg-zinc-50 text-left transition-colors"
                          >
                            <span className={`w-2 h-2 rounded-full flex-shrink-0
   ${dotClass}`} />
                            {name}
                          </button>
                        </li>
                      );
                    })}
                  </ul>
                )}
              </div>
            </div>

            <div className={`transition-all duration-200 overflow-hidden 
  ${isGuest ? 'max-h-24' : 'max-h-0'}`}>
              <label className="block text-xs font-semibold text-zinc-600
  uppercase tracking-wider mb-1.5">
                Payment
              </label>
              <div className="grid grid-cols-2 gap-2">
                <button
                  onClick={() => setPaid(false)}
                  className={`py-2.5 rounded-lg text-sm font-medium border
  transition-all ${!paid ? 'bg-amber-50 border-amber-300 text-amber-700' :
  'border-zinc-200 text-zinc-400 hover:border-zinc-300'}`}
                >
                  Unpaid
                </button>
                <button
                  onClick={() => setPaid(true)}
                  className={`py-2.5 rounded-lg text-sm font-medium border
  transition-all ${paid ? 'bg-emerald-50 border-emerald-300 text-emerald-700' :
  'border-zinc-200 text-zinc-400 hover:border-zinc-300'}`}
                >
                  Paid · ${COST_PER_PERSON_WEEK}
                </button>
              </div>
            </div>

            <div className="flex gap-2 pt-1">
              {!slot.isOwner && (
                <button
                  onClick={handleClear}
                  className="px-3 py-2.5 rounded-lg text-xs font-medium
  text-zinc-400 hover:text-red-500 hover:bg-red-50 border border-zinc-200
  transition-all flex items-center gap-1.5"
                >
                  <Trash2 className="w-3.5 h-3.5" />
                  Clear
                </button>
              )}
              <button onClick={onClose} className="flex-1 py-2.5 rounded-lg
  text-sm font-medium border border-zinc-200 text-zinc-600 hover:bg-zinc-50
  transition-colors">
                Cancel
              </button>
              <button onClick={handleSave} className="flex-1 py-2.5 rounded-lg
  text-sm font-semibold bg-slate-900 text-white hover:bg-slate-800
  transition-colors">
                Save
              </button>
            </div>
          </div>
        </div>
      </div>
    );
  }

