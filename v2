  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16px;
  padding-bottom: 16px;
}

.header-left { display: flex; align-items: center; gap: 12px; }

.wave-icon { width: 20px; height: 20px; color: #38bdf8; flex-shrink: 0; }

.site-title { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; }

.site-sub { font-size: 11px; color: #52525b; margin-top: 2px; }

.header-owners { display: flex; align-items: center; gap: 16px; }

.header-owner { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #71717a; }

/* ── Cards ────────────────────────────────────────────────────────────────── */
