.space-y { display: flex; flex-direction: column; gap: 16px; }

/* ── Empty state ──────────────────────────────────────────────────────────── */
.empty-state { padding: 64px 20px; text-align: center; }
.empty-text  { font-size: 13px; font-weight: 500; color: #a1a1aa; }
.empty-sub   { font-size: 11px; color: #d4d4d8; margin-top: 4px; }

/* ── Text utilities ───────────────────────────────────────────────────────── */
.green    { color: #059669; }
.amber    { color: #f59e0b; }
.red      { color: #ef4444; }
.fw-medium{ font-weight: 500; }
.text-right { text-align: right; }
.text-muted { color: #a1a1aa; }
.text-sm    { font-size: 11px; }

@media (max-width: 640px) { .hide-sm { display: none; } }

/* ── Modal ────────────────────────────────────────────────────────────────── */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 100;
  padding: 0;
}

@media (min-width: 480px) {
  .modal-overlay { align-items: center; padding: 16px; }
}

.modal-overlay.hidden { display: none; }

.modal-box {
  background: white;
  width: 100%;
  max-width: 400px;
  border-radius: 20px 20px 0 0;
  overflow: hidden;
  box-shadow: 0 25px 50px rgba(0,0,0,0.25);
}

@media (min-width: 480px) {
  .modal-box { border-radius: 16px; }
}

.modal-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 20px 20px 16px;
  border-bottom: 1px solid #f4f4f5;
}

.modal-title { font-weight: 600; font-size: 15px; }
.modal-sub   { font-size: 11px; color: #a1a1aa; margin-top: 2px; }

.modal-close {
  width: 32px; height: 32px;
  border: none; background: none;
  cursor: pointer;
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  color: #a1a1aa;
  transition: background 0.1s;
}
.modal-close:hover { background: #f4f4f5; }

.modal-body { padding: 16px 20px 20px; display: flex; flex-direction: column; gap: 16px; }

.modal-meta {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
}
.meta-label { color: #71717a; }
.meta-value { font-weight: 500; }

.form-group { display: flex; flex-direction: column; gap: 6px; }
.form-label {
  font-size: 10px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: #52525b;
}

.input-wrap { position: relative; }

.form-input {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid #e4e4e7;
  border-radius: 8px;
  font-size: 13px;
  font-family: inherit;
  color: #0f172a;
  outline: none;
  transition: border-color 0.15s, box-shadow 0.15s;
}
.form-input:focus { border-color: #0f172a; box-shadow: 0 0 0 2px rgba(15,23,42,0.1); }
.form-input::placeholder { color: #d4d4d8; }

.autocomplete-list {
  position: absolute;
  left: 0; right: 0;
  top: calc(100% + 4px);
  background: white;
  border: 1px solid #e4e4e7;
  border-radius: 8px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  z-index: 10;
  overflow: hidden;
  list-style: none;
}
.autocomplete-list.hidden { display: none; }

.autocomplete-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  font-size: 13px;
  cursor: pointer;
  color: #1e293b;
  transition: background 0.1s;
}
.autocomplete-item:hover { background: #fafafa; }

.payment-group { display: flex; flex-direction: column; gap: 6px; }
.payment-group.hidden { display: none; }

.payment-btns { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

.payment-btn {
  padding: 10px;
  border: 1px solid #e4e4e7;
  border-radius: 8px;
  background: none;
  font-size: 13px;
  font-weight: 500;
  font-family: inherit;
  color: #a1a1aa;
  cursor: pointer;
  transition: all 0.15s;
}
.payment-btn:hover { border-color: #d4d4d8; }
.payment-btn-unpaid-active { background: #fffbeb; border-color: #fcd34d; color: #b45309; }
.payment-btn-paid-active   { background: #ecfdf5; border-color: #6ee7b7; color: #065f46; }

.modal-actions { display: flex; gap: 8px; padding-top: 4px; }

.btn-clear {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 12px;
  border: 1px solid #e4e4e7;
  border-radius: 8px;
  background: none;
  font-size: 11px;
  font-weight: 500;
  font-family: inherit;
  color: #a1a1aa;
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
}
.btn-clear:hover { color: #ef4444; background: #fef2f2; border-color: #fecaca; }

.btn-cancel {
  flex: 1;
  padding: 10px;
  border: 1px solid #e4e4e7;
  border-radius: 8px;
  background: none;
  font-size: 13px;
  font-weight: 500;
  font-family: inherit;
  color: #52525b;
  cursor: pointer;
  transition: background 0.1s;
}
.btn-cancel:hover { background: #fafafa; }

.btn-save {
  flex: 1;
  padding: 10px;
  border: none;
  border-radius: 8px;
  background: #0f172a;
  font-size: 13px;
  font-weight: 600;
  font-family: inherit;
  color: white;
  cursor: pointer;
  transition: background 0.1s;
}
.btn-save:hover { background: #1e293b; }

/* ── Footer ───────────────────────────────────────────────────────────────── */
.site-footer {
  text-align: center;
  padding: 32px 20px;
  font-size: 11px;
  color: #a1a1aa;
}

/* ── Responsive ───────────────────────────────────────────────────────────── */
@media (max-width: 640px) {
  .metric-row  { grid-template-columns: 1fr; }
  .owner-row   { grid-template-columns: 1fr; }
  .header-owners { display: none; }
  .reimb-summary { flex-direction: column; }
  .reimb-divider { width: auto; height: 1px; margin: 8px 0; }
}
